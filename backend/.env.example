# ============================================================
# GoldTrade - Spring Boot Backend Environment Variables
# ============================================================
# Copy this file to .env (same directory) and fill in values.
# NEVER commit .env to version control.
#
# How to get each value:
#   SUPABASE_DB_URL / USERNAME / PASSWORD
#       -> Supabase Dashboard -> Connect (top of project page) -> "Transaction pooler"
#          Copy the URI, e.g. postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
#          Split it into:
#            SUPABASE_DB_URL      = jdbc:postgresql://aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&stringtype=unspecified&prepareThreshold=0
#            SUPABASE_DB_USERNAME = postgres.xxxx
#            SUPABASE_DB_PASSWORD = the database password
#   JWT_SECRET                -> any long random string (e.g. `openssl rand -base64 48`).
#                                 Used to sign/verify GoldTrade's own login tokens — keep it secret.
#   RESEND_API_KEY             -> https://resend.com/api-keys
#   RESEND_FROM_EMAIL          -> "Display Name <address@yourverifieddomain.com>" — the domain
#                                 must show as Verified in Resend -> Domains before this works.
#                                 Defaults to the onboarding@resend.dev sandbox if unset.
#   ADMIN_NOTIFICATION_EMAIL   -> any email address for admin alerts
#   APP_URL                    -> the frontend's URL (http://localhost:3000 in dev)
# ============================================================

SUPABASE_DB_URL=jdbc:postgresql://your-pooler-host.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&stringtype=unspecified&prepareThreshold=0
SUPABASE_DB_USERNAME=postgres.your_project_ref
SUPABASE_DB_PASSWORD=your_supabase_db_password_here
JWT_SECRET=change_me_to_a_long_random_string
RESEND_API_KEY=re_xxxxxxxxx_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=GoldTrade <noreply@goldtrade.markets>
ADMIN_NOTIFICATION_EMAIL=admin@example.com
APP_URL=http://localhost:3000
